# Postgres (Neon — auto-injected when the Marketplace integration is linked).
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Spice account JWT signing secret. Use `openssl rand -base64 64`.
JWT_SECRET=change_me

# Optional separate key for encrypting provider session tokens stored in the DB.
# Falls back to JWT_SECRET when unset.
PROFILE_CONNECTION_SECRET=

# Reserved for later account-link research. YT Music web sessions may require cookies.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# HMAC key for signing short-lived stream URLs (web client → /api/yt/stream).
SPICE_STREAM_HMAC_SECRET=change_me

# Optional stable override for SoundCloud search and playback. If unset, Spice
# discovers the public web-client ID from SoundCloud's frontend assets.
SOUNDCLOUD_CLIENT_ID=

# Last.fm profile sync credentials. Settings exposes one account setup button;
# API key and shared secret stay server-side.
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=
