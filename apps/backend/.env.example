# Postgres (Neon — auto-injected when the Marketplace integration is linked).
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Spice account JWT signing secret. Use `openssl rand -base64 64`.
JWT_SECRET=change_me

# Optional comma-separated admin bootstrap list. Matching new signups start with
# account_role='admin'; existing accounts should be promoted in the database.
SPICE_ADMIN_EMAILS=
SPICE_MOVIE_PROVIDER_BASE_URL=https://vidsrc.sbs/

# Optional separate key for encrypting provider session tokens stored in the DB.
# Falls back to JWT_SECRET when unset.
PROFILE_CONNECTION_SECRET=

# Reserved for later account-link research. YT Music web sessions may require cookies.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/cloud/auth/google/callback

# HMAC key for signing short-lived stream URLs (web client -> /api/local/yt/stream).
SPICE_STREAM_HMAC_SECRET=change_me
SPICE_INSTALL_ORIGIN=https://install.spice-app.xyz
SPICE_LOCAL_UPDATE_MANIFEST_URL=https://music.spice-app.xyz/api/updates/local-windows
SPICE_LOCAL_UPDATE_CHANNEL=stable
SPICE_LOCAL_UPDATE_CHECK_MIN_HOURS=12
SPICE_LOCAL_WINDOWS_VERSION=
SPICE_LOCAL_WINDOWS_DOWNLOAD_URL=https://github.com/Anti-Depressants-Dev-Team/SPICE-but-its-crazier-cuz-yes-/releases/latest/download/spice-local-windows.zip
SPICE_LOCAL_WINDOWS_SHA256=
SPICE_LOCAL_WINDOWS_SIZE_BYTES=
SPICE_LOCAL_WINDOWS_RELEASE_NOTES_URL=
SPICE_LOCAL_LINUX_VERSION=
SPICE_LOCAL_LINUX_DOWNLOAD_URL=https://github.com/Anti-Depressants-Dev-Team/SPICE-but-its-crazier-cuz-yes-/releases/latest/download/spice-local-linux.zip
SPICE_LOCAL_LINUX_SHA256=
SPICE_LOCAL_LINUX_SIZE_BYTES=
SPICE_LOCAL_LINUX_RELEASE_NOTES_URL=

# Optional stable override for SoundCloud search and playback. If unset, Spice
# discovers the public web-client ID from SoundCloud's frontend assets.
SOUNDCLOUD_CLIENT_ID=

# Last.fm profile sync credentials. Settings exposes one account setup button;
# API key and shared secret stay server-side.
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=

