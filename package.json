{
  "name": "spice",
  "version": "1.4.19",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:native": "node scripts/start-native.js",
    "start:hidden": "npx cross-env ELECTRON_RUN_AS_NODE=1 node -e \"require('child_process').spawn(require('electron'), ['.'], {detached: true, stdio: 'ignore'}).unref()\"",
    "start:vbs": "echo Set WshShell = CreateObject(\"WScript.Shell\") > start.vbs && echo WshShell.Run \"npm start\", 0, false >> start.vbs && cscript start.vbs && del start.vbs",
    "dist": "electron-builder",
    "native:prepare-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-native-runtime.ps1",
    "dist:native": "npm run native:prepare-runtime && electron-builder --win --config electron-builder.native.cjs",
    "test": "node --test test/lyrics-core.test.js test/runtime-manager.test.js",
    "mobile:test": "npm --prefix apps/mobile test",
    "mobile:build": "npm --prefix apps/mobile run android:debug",
    "mobile:android:debug": "npm --prefix apps/mobile run android:debug",
    "mobile:android:check": "npm --prefix apps/mobile run android:check",
    "mobile:android:release": "npm --prefix apps/mobile run android:release",
    "mobile:android:release:check": "npm --prefix apps/mobile run android:release:check"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "Anti-Depressants-Dev-Team",
        "repo": "spice",
        "releaseType": "release"
      }
    ],
    "files": [
      "**/*",
      "!native-runtime/**",
      "!dist/**",
      "!dist-native/**"
    ],
    "appId": "com.spice.app",
    "productName": "Spice",
    "artifactName": "Spice-Setup-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "flatpak",
        "deb",
        "tar.gz"
      ],
      "icon": "icon.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anti-Depressants-Dev-Team/spice.git"
  },
  "keywords": [],
  "author": "Spice Developer <lutylutanu0@gmail.com>",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Anti-Depressants-Dev-Team/spice/issues"
  },
  "homepage": "https://github.com/Anti-Depressants-Dev-Team/spice#readme",
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "@xhayper/discord-rpc": "^1.3.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-fetch": "^2.7.0"
  }
}
